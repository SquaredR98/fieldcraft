{
  "name": "@squaredr/fieldcraft-react",
  "version": "1.0.0",
  "description": "React renderer for @squaredr/fieldcraft-core — 35+ pre-built form fields, hooks, theming, and a pluggable field registry. Styled with Tailwind CSS via shadcn/ui primitives.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts && npx @tailwindcss/cli -i src/styles/formengine.css -o dist/styles.css --minify",
    "build:css": "npx @tailwindcss/cli -i src/styles/formengine.css -o dist/styles.css --minify",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@squaredr/fieldcraft-core": "workspace:*",
    "radix-ui": "^1.4.3"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@radix-ui/react-checkbox": "^1.0",
    "@radix-ui/react-dialog": "^1.0",
    "@radix-ui/react-dropdown-menu": "^1.0",
    "@radix-ui/react-label": "^2.0",
    "@radix-ui/react-popover": "^1.0",
    "@radix-ui/react-progress": "^1.0",
    "@radix-ui/react-radio-group": "^1.0",
    "@radix-ui/react-select": "^2.0",
    "@radix-ui/react-slider": "^1.0",
    "@radix-ui/react-switch": "^1.0",
    "@radix-ui/react-toggle": "^1.0",
    "@radix-ui/react-tooltip": "^1.0",
    "@squaredr/eslint-config": "workspace:*",
    "@squaredr/tailwind-config": "workspace:*",
    "@squaredr/tsconfig": "workspace:*",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@tailwindcss/cli": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7",
    "clsx": "^2.1",
    "cmdk": "^1.0",
    "date-fns": "^3.6",
    "framer-motion": "^11.0",
    "jsdom": "^29.0.0",
    "lucide-react": "^0.400",
    "react-day-picker": "^8.10",
    "react-dropzone": "^14.2",
    "shadcn": "^4.0.8",
    "signature_pad": "^5.0",
    "storybook": "^8.6.14",
    "tailwind-merge": "^2.5",
    "tailwindcss": "^4.0",
    "tsup": "^8.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.5",
    "vitest": "^2.0"
  },
  "keywords": [
    "fieldcraft",
    "react-forms",
    "form-components",
    "shadcn-ui",
    "radix-ui",
    "tailwindcss",
    "schema-driven",
    "multi-step-forms",
    "form-renderer",
    "typescript",
    "conditional-logic"
  ],
  "license": "MIT",
  "author": "SquaredR",
  "homepage": "https://github.com/squaredr/fieldcraft#readme",
  "bugs": {
    "url": "https://github.com/squaredr/fieldcraft/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/squaredr/fieldcraft.git",
    "directory": "packages/react"
  },
  "engines": {
    "node": ">=18"
  }
}
