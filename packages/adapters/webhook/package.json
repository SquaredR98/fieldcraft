{
  "name": "@squaredr/formengine-webhook",
  "version": "0.0.1",
  "description": "FormEngine webhook delivery adapter with HMAC signing and retries",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@squaredr/formengine-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.5",
    "tsup": "^8.0",
    "vitest": "^2.0"
  },
  "license": "PROPRIETARY"
}
