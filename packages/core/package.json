{
  "name": "@squaredr/fieldcraft-core",
  "version": "1.0.0",
  "description": "Headless TypeScript form engine with zero UI dependencies. Define multi-section forms via JSON schemas with validation, conditional visibility, and computed fields.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23"
  },
  "devDependencies": {
    "typescript": "^5.5",
    "tsup": "^8.0",
    "vitest": "^2.0",
    "@squaredr/tsconfig": "workspace:*",
    "@squaredr/eslint-config": "workspace:*"
  },
  "keywords": [
    "fieldcraft",
    "form-engine",
    "form-builder",
    "schema-driven",
    "conditional-logic",
    "multi-step-forms",
    "form-validation",
    "computed-fields",
    "json-forms",
    "questionnaire",
    "typescript",
    "headless"
  ],
  "license": "MIT",
  "author": "SquaredR",
  "homepage": "https://github.com/squaredr/fieldcraft#readme",
  "bugs": {
    "url": "https://github.com/squaredr/fieldcraft/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/squaredr/fieldcraft.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=18"
  }
}
